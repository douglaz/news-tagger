#!/usr/bin/env bash
set -euo pipefail

if command -v nix >/dev/null 2>&1 && [ -f "flake.nix" ]; then
    if ! nix develop -c cargo fmt --all -- --check 2>/dev/null; then
        echo "Code is not formatted. Run 'nix develop -c cargo fmt --all' before committing."
        echo ""
        echo "To see what needs formatting:"
        echo "  nix develop -c cargo fmt --all -- --check --verbose"
        exit 1
    fi
else
    if ! cargo fmt --all -- --check 2>/dev/null; then
        echo "Code is not formatted. Run 'cargo fmt --all' before committing."
        exit 1
    fi
fi

echo "Formatting check passed"
